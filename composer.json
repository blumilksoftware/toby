{
    "name": "blumilksoftware/toby",
    "type": "project",
    "description": "HR software you love to hate",
    "keywords": ["toby", "laravel", "hr"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-redis": "*",
        "azuyalabs/yasumi": "^2.11.0",
        "barryvdh/laravel-dompdf": "^3.1.2",
        "dompdf/dompdf": "^3.1.5",
        "fakerphp/faker": "^1.24.1",
        "guzzlehttp/guzzle": "^7.10.6",
        "inertiajs/inertia-laravel": "^2.0.24",
        "laragear/cache-query": "^6.0.0",
        "laravel/framework": "^12.0.1",
        "laravel/sanctum": "^4.3.2",
        "laravel/socialite": "^5.28.0",
        "laravel/telescope": "^5.20.0",
        "laravel/tinker": "^2.11.1",
        "maatwebsite/excel": "^3.1.69",
        "phpoffice/phpword": "^1.4.0",
        "sentry/sentry-laravel": "^4.26.0",
        "spatie/laravel-google-calendar": "^3.8.5",
        "spatie/laravel-model-states": "^2.14.1",
        "spatie/laravel-permission": "^6.25.0",
        "spatie/laravel-slack-slash-command": "^1.13.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0.10",
        "blumilksoftware/codestyle": "^5.1.1",
        "laravel/dusk": "^8.6.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "phpunit/phpunit": "^12.0.10",
        "spatie/laravel-ignition": "^2.12.0"
    },
    "autoload": {
        "psr-4": {
            "Toby\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "PHP_CS_FIXER_IGNORE_ENV=1 ./vendor/bin/php-cs-fixer fix --dry-run --diff --config codestyle.php",
        "csf": "PHP_CS_FIXER_IGNORE_ENV=1 ./vendor/bin/php-cs-fixer fix --diff --config codestyle.php",
        "test": [
            "@putenv XDEBUG_MODE=off",
            "@php artisan test"
        ],
        "fresh": "@php artisan migrate:fresh",
        "fresh:demo": [
            "composer fresh",
            "@php artisan db:seed --class=DemoSeeder"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope",
                "spatie/laravel-slack-slash-command"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
